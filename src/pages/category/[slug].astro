---
import {
	getTerm,
	getEmDashCollection,
	getTermsForEntries,
	decodeSlug,
} from "emdash";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("category", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	where: { category: term.slug },
	orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const tagsByEntry = await getTermsForEntries(
	"posts",
	posts.map((p) => p.data.id),
	"tag",
);

const getFirstTag = (id: string) => tagsByEntry.get(id)?.[0] ?? null;

const formatDate = (date: Date) =>
	date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});

const countLabel = posts.length === 1 ? "essay" : "essays";
---

<Base title={`${term.label} posts`} description={`All posts in ${term.label}`}>
	<div class="archive-page" style="container-type: inline-size;">
		<section class="archive-hero">
			<div class="grid-lines" aria-hidden="true" />
			<div class="hero-inner">
				<p class="hero-kicker">
					Category · {posts.length}
					{countLabel}
				</p>
				<h1 class="hero-h">{term.label}.</h1>
				<p class="hero-sub">
					{
						term.description ??
							`Posts filed under ${term.label.toLowerCase()}.`
					}
				</p>
			</div>
		</section>

		<section class="posts-section">
			<div class="section-inner">
				{
					posts.length === 0 ? (
						<p class="empty">No posts in this category yet.</p>
					) : (
						<div class="erows">
							{posts.map((post, i) => {
								const tag = getFirstTag(post.data.id);
								return (
									<a class="erow" href={`/posts/${post.id}`}>
										<span class="erow-idx">
											{String(i + 1).padStart(2, "0")}
										</span>
										<div class="erow-content">
											<div class="erow-title">{post.data.title}</div>
											<div class="erow-meta">
												{post.data.publishedAt && (
													<time>{formatDate(post.data.publishedAt)}</time>
												)}
												<span>·</span>
												<span>
													{getReadingTime(post.data.content)} min read
												</span>
											</div>
										</div>
										<div class="erow-right">
											{tag && (
												<span class="erow-tag">
													#{tag.label.toLowerCase().replace(/\s+/g, "-")}
												</span>
											)}
											<span class="erow-arrow" aria-hidden="true">
												→
											</span>
										</div>
									</a>
								);
							})}
						</div>
					)
				}
			</div>
		</section>
	</div>
</Base>

<style>
	.archive-page {
		min-height: 60vh;
	}

	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6);
	}

	/* ── HERO ── */
	.archive-hero {
		position: relative;
		padding: 3.5rem var(--spacing-6) 2.5rem;
	}

	.grid-lines {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background-image: linear-gradient(
			to right,
			var(--color-border) 1px,
			transparent 1px
		);
		background-size: 25% 100%;
		opacity: 0.35;
	}

	.hero-inner {
		position: relative;
		max-width: var(--wide-width);
		margin: 0 auto;
		z-index: 1;
	}

	.hero-kicker {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
		display: flex;
		align-items: center;
		gap: 0.625rem;
		margin-bottom: 1.375rem;
	}

	.hero-kicker::before {
		content: "";
		width: 1.625rem;
		height: 1.5px;
		background: var(--color-accent);
		flex-shrink: 0;
	}

	.hero-h {
		font-family: var(--font-display);
		font-weight: 800;
		letter-spacing: -0.038em;
		line-height: 0.92;
		font-size: clamp(2.75rem, 9cqw, 5.25rem);
		margin-bottom: 1.375rem;
	}

	.hero-sub {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		max-width: 33.75rem;
	}

	/* ── POSTS SECTION ── */
	.posts-section {
		padding: 0 0 4rem;
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		padding: var(--spacing-12) 0;
	}

	/* ── EDITORIAL ROWS ── */
	.erows {
		border-top: 1.5px solid var(--color-text);
	}

	.erow {
		position: relative;
		display: grid;
		grid-template-columns: 5.25rem 1fr auto;
		align-items: center;
		gap: 1.375rem;
		padding: 1.625rem 1.25rem 1.625rem 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		color: inherit;
		cursor: pointer;
		transition:
			padding 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
			color 0.2s;
		isolation: isolate;
	}

	.erow::before {
		content: "";
		position: absolute;
		inset: 0;
		background: var(--color-accent);
		transform: scaleY(0);
		transform-origin: bottom;
		transition: transform 0.28s cubic-bezier(0.2, 0.7, 0.2, 1);
		z-index: -1;
	}

	.erow:hover {
		padding-left: 1.375rem;
		padding-right: 1.75rem;
		color: var(--color-on-accent);
	}

	.erow:hover::before {
		transform: scaleY(1);
	}

	.erow:hover .erow-idx,
	.erow:hover .erow-meta,
	.erow:hover .erow-tag {
		color: color-mix(in srgb, var(--color-on-accent) 80%, transparent);
		border-color: color-mix(in srgb, var(--color-on-accent) 50%, transparent);
	}

	.erow-idx {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-muted);
		transition: color 0.2s;
	}

	.erow-content {
		min-width: 0;
	}

	.erow-title {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: clamp(1.1875rem, 3.1cqw, 1.875rem);
		letter-spacing: -0.02em;
		line-height: 1.08;
	}

	.erow-meta {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
		transition: color 0.2s;
		margin-top: 0.5rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.erow-right {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-shrink: 0;
	}

	.erow-tag {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		padding: 3px 9px;
		border: 1px solid var(--color-border);
		color: var(--color-text-secondary);
		transition:
			color 0.2s,
			border-color 0.2s;
		white-space: nowrap;
	}

	.erow-arrow {
		font-size: 1.125rem;
		opacity: 0;
		transform: translateX(-8px);
		transition:
			opacity 0.28s cubic-bezier(0.2, 0.7, 0.2, 1),
			transform 0.28s cubic-bezier(0.2, 0.7, 0.2, 1);
	}

	.erow:hover .erow-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.archive-hero {
			padding: 2.5rem var(--spacing-4) 2rem;
		}

		.section-inner {
			padding: 0 var(--spacing-4);
		}

		.erow {
			grid-template-columns: 3.5rem 1fr auto;
			gap: 0.875rem;
		}

		.erow-tag {
			display: none;
		}
	}

	@media (max-width: 600px) {
		.erow {
			grid-template-columns: 3rem 1fr 1.5rem;
			gap: 0.75rem;
			padding: 1.25rem 0.75rem 1.25rem 0;
		}

		.erow:hover {
			padding-left: 1rem;
		}
	}
</style>
