---
import {
	getEmDashCollection,
	getEmDashEntry,
	getTermsForEntries,
	getSiteSettings,
} from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const POSTS_LIMIT = 7;

const [{ entries: posts, cacheHint }, settings, homepageResult] =
	await Promise.all([
		getEmDashCollection("posts", {
			orderBy: { published_at: "desc" },
			limit: POSTS_LIMIT + 1,
		}),
		getSiteSettings(),
		getEmDashEntry("homepage", "home"),
	]);

const { siteTitle, siteTagline } = resolveBlogSiteIdentity(settings);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const home = homepageResult.entry?.data ?? {};

const visiblePosts = posts.slice(0, POSTS_LIMIT);
const hasMorePosts = posts.length > POSTS_LIMIT;

const featuredPost = visiblePosts[0] ?? null;
const rowPosts = visiblePosts.slice(1);

const tagsByEntry = await getTermsForEntries(
	"posts",
	visiblePosts.map((p) => p.data.id),
	"tag",
);

const getFirstTag = (id: string) => tagsByEntry.get(id)?.[0] ?? null;

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}

const heroKicker = home.hero_kicker ?? "";
const heroPreAccent = home.hero_heading_pre_accent ?? "";
const heroAccent = home.hero_heading_accent ?? "";
const heroMiddle = home.hero_heading_middle ?? "";
const heroItalic = home.hero_heading_italic ?? "";
const heroPostItalic = home.hero_heading_post_italic ?? "";
const heroLead = home.hero_lead ?? siteTagline;
const heroCtaLabel = home.hero_cta_label ?? "read the writing";
const heroCtaUrl = home.hero_cta_url ?? "/posts";

const terminalTitle = home.terminal_title ?? "";
const terminalLines: string =
	typeof home.terminal_lines === "string" ? home.terminal_lines : "";

const stats: Array<{ fig: string; lbl: string }> = Array.isArray(home.stats)
	? home.stats
	: [];

const writingNum = home.writing_section_number ?? "01";
const writingTitle = home.writing_section_title ?? "Writing";

const ctaKicker = home.cta_kicker ?? "";
const ctaH1 = home.cta_heading_line_1 ?? "";
const ctaH2 = home.cta_heading_line_2 ?? "";
const ctaEmail = home.cta_email ?? "";
const ctaButtonLabel = home.cta_button_label ?? "send email";
---

<Base title={siteTitle} description={siteTagline}>
	{
		posts.length === 0 ? (
			<section class="empty-state">
				<h2>No posts yet</h2>
				<p>Create your first post in the admin panel.</p>
				<a href="/_emdash/admin/content/posts/new" class="btn-primary">
					Create a post
				</a>
			</section>
		) : (
			<div class="home">
				{/* ── HERO ── */}
				<section class="hero">
					<div class="grid-lines" aria-hidden="true" />
					<div class="hero-inner">
						{heroKicker && <p class="hero-kicker">{heroKicker}</p>}
						<h1 class="hero-h">
							{heroPreAccent}{" "}
							<span class="hero-acc">{heroAccent}</span>
							<br />
							{heroMiddle}
							<br />
							<em>{heroItalic}</em> {heroPostItalic}
						</h1>
						<div class="hero-body">
							<div class="hero-text">
								<p class="hero-lead">{heroLead}</p>
								<div class="hero-pills">
									<a href={heroCtaUrl} class="pill pill-solid">
										{heroCtaLabel} <span aria-hidden="true">→</span>
									</a>
								</div>
							</div>
							{(terminalTitle || terminalLines) && (
								<div class="hero-term">
									<div class="term-bar">
										<span class="term-dots" aria-hidden="true">
											<i class="term-dot term-dot-acc" />
											<i class="term-dot" />
											<i class="term-dot" />
										</span>
										<span>{terminalTitle}</span>
									</div>
									<div class="term-body">
										<code
											id="term-output"
											class="term-text"
											data-lines={terminalLines}
											aria-live="off"
										/>
										<span class="term-cursor" aria-hidden="true" />
									</div>
								</div>
							)}
						</div>
					</div>
				</section>

				{/* ── STATS STRIP ── */}
				{stats.length > 0 && (
					<div class="stats-wrap">
						<div class="stats-strip">
							{stats.map((s, i) => (
								<div class={`stat${i === 0 ? " stat-noborder" : ""}`}>
									<div class="stat-fig">{s.fig}</div>
									<div class="stat-lbl">{s.lbl}</div>
								</div>
							))}
						</div>
					</div>
				)}

				{/* ── WRITING ── */}
				<section class="writing-section">
					<div class="section-inner">
						<div class="sec-head">
							<span class="sec-num">{writingNum}</span>
							<h2 class="sec-title">{writingTitle}</h2>
							{hasMorePosts && (
								<a href="/posts" class="sec-link">
									all posts →
								</a>
							)}
						</div>

						{/* Featured post */}
						{featuredPost && (
							<a class="featured-post" href={`/posts/${featuredPost.id}`}>
								<div class="featured-img">
									{featuredPost.data.featured_image ? (
										<Image image={featuredPost.data.featured_image} />
									) : (
										<div class="img-placeholder">
											<span>{featuredPost.data.title}</span>
										</div>
									)}
								</div>
								<div class="featured-text">
									<div class="featured-meta">
										<span class="featured-badge">● FEATURED</span>
										{featuredPost.data.publishedAt && (
											<>
												<span>·</span>
												<time>
													{formatDate(featuredPost.data.publishedAt)}
												</time>
											</>
										)}
										<span>·</span>
										<span>{getReadingTime(featuredPost.data.content)} min</span>
									</div>
									<h3 class="featured-title">{featuredPost.data.title}</h3>
									{featuredPost.data.excerpt && (
										<p class="featured-excerpt">
											{featuredPost.data.excerpt}
										</p>
									)}
									<span class="pill pill-ghost featured-cta">
										read essay →
									</span>
								</div>
							</a>
						)}

						{/* Editorial rows */}
						{rowPosts.length > 0 && (
							<div class="erows">
								{rowPosts.map((post, i) => {
									const tag = getFirstTag(post.data.id);
									return (
										<a class="erow" href={`/posts/${post.id}`}>
											<span class="erow-idx">
												{String(i + 2).padStart(2, "0")}
											</span>
											<div class="erow-content">
												<div class="erow-title">{post.data.title}</div>
												<div class="erow-meta">
													{post.data.publishedAt && (
														<time>{formatDate(post.data.publishedAt)}</time>
													)}
													<span>·</span>
													<span>
														{getReadingTime(post.data.content)} min read
													</span>
												</div>
											</div>
											<div class="erow-right">
												{tag && (
													<span class="erow-tag">
														#{tag.label.toLowerCase().replace(/\s+/g, "-")}
													</span>
												)}
												<span class="erow-arrow" aria-hidden="true">
													→
												</span>
											</div>
										</a>
									);
								})}
							</div>
						)}
					</div>
				</section>

				{/* ── CTA ── */}
				{(ctaKicker || ctaH1 || ctaH2 || ctaEmail) && (
					<section class="cta-section">
						<div class="section-inner">
							<div class="cta-block">
								<div>
									{ctaKicker && <p class="cta-kicker">{ctaKicker}</p>}
									<h2 class="cta-h">
										{ctaH1}
										{ctaH1 && ctaH2 && <br />}
										{ctaH2}
									</h2>
								</div>
								<div class="cta-right">
									{ctaEmail && (
										<>
											<code class="cta-email">$ mailx {ctaEmail}</code>
											<a href={`mailto:${ctaEmail}`} class="cta-btn">
												{ctaButtonLabel} →
											</a>
										</>
									)}
								</div>
							</div>
						</div>
					</section>
				)}
			</div>
		)
	}
</Base>

<script>
	const output = document.getElementById("term-output") as HTMLElement | null;
	if (output) {
		const flat = output.dataset.lines ?? "";
		let pos = 0;

		const tick = () => {
			output.textContent = flat.slice(0, pos);
			if (pos < flat.length) {
				pos++;
				setTimeout(tick, pos === 1 ? 500 : 22 + Math.random() * 14);
			}
		};

		if (flat) setTimeout(tick, 800);
	}
</script>

<style>
	/* ── Layout ── */
	.home {
		container-type: inline-size;
	}

	.section-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6);
	}

	/* ── Empty state ── */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-3);
		text-align: center;
		padding: var(--spacing-20) var(--spacing-6);
		max-width: 400px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-size: var(--font-size-2xl);
	}

	.empty-state p {
		color: var(--color-muted);
	}

	.btn-primary {
		display: inline-block;
		margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	/* ── HERO ── */
	.hero {
		position: relative;
		padding: 4rem var(--spacing-6) 3.5rem;
	}

	.grid-lines {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background-image: linear-gradient(
			to right,
			var(--color-border) 1px,
			transparent 1px
		);
		background-size: 25% 100%;
		opacity: 0.35;
	}

	.hero-inner {
		position: relative;
		max-width: var(--wide-width);
		margin: 0 auto;
		z-index: 1;
	}

	.hero-kicker {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
		display: flex;
		align-items: center;
		gap: 0.625rem;
		margin-bottom: 1.625rem;
	}

	.hero-kicker::before {
		content: "";
		width: 1.625rem;
		height: 1.5px;
		background: var(--color-accent);
		flex-shrink: 0;
	}

	.hero-h {
		font-family: var(--font-display);
		font-weight: 800;
		letter-spacing: -0.038em;
		line-height: 0.92;
		font-size: clamp(2.375rem, 8.6cqw, 5.125rem);
		margin-bottom: 0;
	}

	.hero-acc {
		color: var(--color-accent);
	}

	.hero-h em {
		font-style: italic;
		font-weight: 600;
	}

	.hero-body {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.75rem;
		align-items: start;
		margin-top: 2.375rem;
	}

	.hero-lead {
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		max-width: 28.75rem;
		margin-bottom: 1.625rem;
	}

	.hero-pills {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	/* Pill buttons */
	.pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 500;
		padding: 0.75rem 1.125rem;
		border: 1.5px solid var(--color-text);
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform 0.16s,
			box-shadow 0.16s;
		background: transparent;
		cursor: pointer;
		white-space: nowrap;
	}

	.pill:hover {
		transform: translate(-3px, -3px);
		box-shadow: 5px 5px 0 var(--color-accent);
		color: var(--color-text);
	}

	.pill-solid {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.pill-solid:hover {
		color: var(--color-bg);
	}

	.pill-ghost {
		border-color: var(--color-border);
		color: var(--color-text-secondary);
	}

	.pill-ghost:hover {
		color: var(--color-text);
	}

	/* Terminal block */
	.hero-term {
		border: 1.5px solid var(--color-text);
		background: var(--color-surface);
		font-family: var(--font-mono);
	}

	.term-bar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5625rem 0.875rem;
		border-bottom: 1.5px solid var(--color-border);
		font-size: 0.71875rem;
		color: var(--color-muted);
	}

	.term-dots {
		display: inline-flex;
		gap: 5px;
	}

	.term-dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--color-border);
		display: inline-block;
	}

	.term-dot-acc {
		background: var(--color-accent);
	}

	.term-body {
		padding: 1rem 1rem 1.125rem;
		font-size: 0.8125rem;
		line-height: 1.75;
		color: var(--color-text-secondary);
		min-height: 8rem;
	}

	.term-text {
		white-space: pre;
		font-family: inherit;
		font-size: inherit;
		display: inline;
	}

	.term-cursor {
		display: inline-block;
		width: 0.55em;
		height: 1em;
		background: var(--color-accent);
		vertical-align: -0.13em;
		margin-left: 2px;
		animation: blink 1.05s steps(2, end) infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	/* ── STATS ── */
	.stats-wrap {
		padding: 0.5rem var(--spacing-6) 3.5rem;
	}

	.stats-strip {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		border-top: 1.5px solid var(--color-text);
		border-bottom: 1.5px solid var(--color-text);
	}

	.stat {
		padding: 1.75rem 1.125rem;
		border-left: 1px solid var(--color-border);
	}

	.stat-noborder {
		border-left: none;
	}

	.stat-fig {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(2.125rem, 7cqw, 4rem);
		letter-spacing: -0.04em;
		line-height: 0.9;
		color: var(--color-accent);
	}

	.stat-lbl {
		font-family: var(--font-mono);
		font-size: 0.71875rem;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-top: 0.625rem;
	}

	/* ── SECTION HEADER ── */
	.sec-head {
		display: flex;
		align-items: baseline;
		gap: 1.125rem;
		padding-bottom: 0.875rem;
		border-bottom: 1.5px solid var(--color-text);
		margin-bottom: 2rem;
	}

	.sec-num {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-accent);
		letter-spacing: 0.04em;
	}

	.sec-title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(1.5rem, 4.2cqw, 2.5rem);
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.sec-link {
		margin-left: auto;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
		text-decoration: none;
		align-self: flex-end;
		transition: color var(--transition-fast);
		white-space: nowrap;
	}

	.sec-link:hover {
		color: var(--color-accent);
	}

	/* ── WRITING SECTION ── */
	.writing-section {
		padding: 0 0 4rem;
	}

	/* Featured post */
	.featured-post {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
		align-items: center;
		margin-bottom: 1.125rem;
		text-decoration: none;
		color: inherit;
	}

	.featured-img {
		aspect-ratio: 4 / 3;
		min-height: 220px;
		overflow: hidden;
		border: 1.5px solid var(--color-border);
	}

	.featured-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.featured-post:hover .featured-img img {
		transform: scale(1.02);
	}

	.img-placeholder {
		width: 100%;
		height: 100%;
		background: repeating-linear-gradient(
			135deg,
			var(--color-surface) 0 12px,
			var(--color-border-subtle) 12px 24px
		);
		display: flex;
		align-items: flex-end;
		justify-content: flex-start;
		padding: 0.75rem;
	}

	.img-placeholder span {
		font-family: var(--font-mono);
		font-size: 0.71875rem;
		color: var(--color-muted);
		background: color-mix(in srgb, var(--color-bg) 85%, transparent);
		padding: 0.25rem 0.625rem;
		border: 1px solid var(--color-border);
	}

	.featured-text {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.featured-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
		flex-wrap: wrap;
	}

	.featured-badge {
		color: var(--color-accent);
		font-weight: 500;
	}

	.featured-title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(1.75rem, 4.4cqw, 2.75rem);
		letter-spacing: -0.025em;
		line-height: 1.05;
		transition: color var(--transition-fast);
	}

	.featured-post:hover .featured-title {
		color: var(--color-accent);
	}

	.featured-excerpt {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.featured-cta {
		align-self: flex-start;
		margin-top: 0.375rem;
	}

	/* ── EDITORIAL ROWS ── */
	.erows {
		margin-top: 1.75rem;
	}

	.erow {
		position: relative;
		display: grid;
		grid-template-columns: 5.25rem 1fr auto;
		align-items: center;
		gap: 1.375rem;
		padding: 1.625rem 1.25rem 1.625rem 0;
		border-top: 1px solid var(--color-border);
		text-decoration: none;
		color: inherit;
		cursor: pointer;
		transition:
			padding 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
			color 0.2s;
		isolation: isolate;
	}

	.erow:last-child {
		border-bottom: 1px solid var(--color-border);
	}

	.erow::before {
		content: "";
		position: absolute;
		inset: 0;
		background: var(--color-accent);
		transform: scaleY(0);
		transform-origin: bottom;
		transition: transform 0.28s cubic-bezier(0.2, 0.7, 0.2, 1);
		z-index: -1;
	}

	.erow:hover {
		padding-left: 1.375rem;
		padding-right: 1.75rem;
		color: var(--color-on-accent);
	}

	.erow:hover::before {
		transform: scaleY(1);
	}

	.erow:hover .erow-idx,
	.erow:hover .erow-meta,
	.erow:hover .erow-tag {
		color: color-mix(in srgb, var(--color-on-accent) 80%, transparent);
		border-color: color-mix(in srgb, var(--color-on-accent) 50%, transparent);
	}

	.erow-idx {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-muted);
		transition: color 0.2s;
	}

	.erow-content {
		min-width: 0;
	}

	.erow-title {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: clamp(1.1875rem, 3.1cqw, 1.875rem);
		letter-spacing: -0.02em;
		line-height: 1.08;
	}

	.erow-meta {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
		transition: color 0.2s;
		margin-top: 0.5rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.erow-right {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-shrink: 0;
	}

	.erow-tag {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		padding: 3px 9px;
