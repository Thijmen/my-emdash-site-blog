---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getTermsForEntries,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
	WidgetArea,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}

const featuredImageUrl = getImageUrl(post.data.featured_image);
const featuredImageAlt =
	post.data.featured_image &&
	typeof post.data.featured_image === "object" &&
	"alt" in (post.data.featured_image as object)
		? ((post.data.featured_image as Record<string, unknown>).alt as string)
		: undefined;

const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

const [tags, categories, { entries: recentPosts }] = await Promise.all([
	getEntryTerms("posts", post.data.id, "tag"),
	getEntryTerms("posts", post.data.id, "category"),
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
]);

const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

const otherTagsByEntry = await getTermsForEntries(
	"posts",
	otherPosts.map((p) => p.data.id),
	"tag",
);

const otherPostsWithTags = otherPosts.map((p) => ({
	post: p,
	tags: otherTagsByEntry.get(p.data.id) ?? [],
}));

const publishDate = post.data.publishedAt
	? post.data.publishedAt.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: null;

const publishDateShort = post.data.publishedAt
	? post.data.publishedAt.toLocaleDateString("en-US", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;

function getInitials(name: string) {
	return name
		.split(" ")
		.map((w) => w[0] ?? "")
		.join("")
		.toUpperCase()
		.slice(0, 2);
}

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<div class="readbar" id="readbar" aria-hidden="true" />

	{/* ── ARTICLE HEADER ── */}
	<header class="post-head">
		<div class="grid-lines" aria-hidden="true" />
		<div class="post-wrap" style="position: relative;">
			<div class="crumb">
				<a href="/posts">Posts</a>
				<span class="crumb-arrow">→</span>
				<span>{post.data.title}</span>
			</div>

			<div class="metarow">
				{
					categories[0] && (
						<span class="tag-pill">#{categories[0].label}</span>
					)
				}
				{
					publishDate && (
						<span class="meta-mono">
							{publishDate.toUpperCase()} · {readingTime} MIN READ
						</span>
					)
				}
				{
					!publishDate && (
						<span class="meta-mono">{readingTime} MIN READ</span>
					)
				}
			</div>

			<h1 class="post-title" {...post.edit.title}>{post.data.title}</h1>

			{
				post.data.excerpt && (
					<p class="post-dek" {...post.edit.excerpt}>
						{post.data.excerpt}
					</p>
				)
			}

			{
				bylines.length > 0 && (
					<div class="byline-bar">
						{bylines.map((credit) => (
							<div class="byline-left">
								{credit.byline.avatarMediaId ? (
									<img
										src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
										alt={credit.byline.displayName}
										class="byline-sq byline-sq-img"
									/>
								) : (
									<span class="byline-sq">
										{getInitials(credit.byline.displayName)}
									</span>
								)}
								<div>
									<div class="byline-name">{credit.byline.displayName}</div>
									<div class="byline-sub">
										{credit.roleLabel ?? "Staff Software Engineer · Amsterdam"}
									</div>
								</div>
							</div>
						))}
						<div class="byline-actions">
							<button class="abtn" aria-label="Share this post">
								↗ share
							</button>
							<a href="/rss.xml" class="abtn" aria-label="Subscribe via RSS">
								⌁ subscribe
							</a>
						</div>
					</div>
				)
			}
		</div>
	</header>

	{/* ── HERO IMAGE ── */}
	{
		post.data.featured_image && (
			<div class="post-wrap">
				<figure class="hero-fig" {...post.edit.featured_image}>
					<div class="hero-img-wrap">
						<Image image={post.data.featured_image} />
					</div>
					{featuredImageAlt && (
						<figcaption class="hero-cap">
							<span class="hero-dot">●</span>
							{featuredImageAlt}
						</figcaption>
					)}
				</figure>
			</div>
		)
	}

	{/* ── TWO-COLUMN LAYOUT ── */}
	<div class="post-wrap post-layout">
		<main>
			<article class="prose" id="article-prose">
				<PortableText value={post.data.content} />
			</article>

			<div class="endmatter">
				<span class="endmatter-note">
					Thanks for reading. Found a typo? <a href={`mailto:thijmenstavenuiter@gmail.com?subject=Typo in ${post.data.title}`}>Let me know →</a>
				</span>
				{
					tags.length > 0 && (
						<div class="tag-list">
							{tags.map((t) => (
								<a class="tag-chip" href={`/tag/${t.slug}`}>
									#{t.slug}
								</a>
							))}
						</div>
					)
				}
			</div>

			<section class="comments-wrap">
				<Comments collection="posts" contentId={post.data.id} threaded />
				<CommentForm collection="posts" contentId={post.data.id} />
			</section>
		</main>

		<aside class="sidebar">
			<div class="widget">
				<h4 class="widget-title">On this page</h4>
				<nav class="toc-nav" id="toc-content" aria-label="Table of contents">
				</nav>
			</div>
			<div class="sidebar-widgets">
				<WidgetArea name="sidebar" />
			</div>
		</aside>
	</div>

	{/* ── CONTINUE READING ── */}
	{
		otherPostsWithTags.length > 0 && (
			<div class="post-wrap">
				<section class="more">
					<div class="more-head">
						<span class="more-arrow">→</span>
						<h2 class="more-title">Continue reading</h2>
					</div>
					<div class="more-cards">
						{otherPostsWithTags.map(({ post: p, tags: postTags }) => (
							<a class="bcard" href={`/posts/${p.id}`}>
								<div class="bcard-ph" />
								<div class="bcard-body">
									<div class="bcard-meta">
										{p.data.publishedAt && (
											<time>{formatDate(p.data.publishedAt)}</time>
										)}
										<span>· {getReadingTime(p.data.content)} min</span>
									</div>
									<div class="bcard-title">{p.data.title}</div>
									{p.data.excerpt && (
										<div class="bcard-exc">{p.data.excerpt}</div>
									)}
									{postTags[0] && (
										<div class="bcard-tag">
											#{postTags[0].label.toLowerCase()}
										</div>
									)}
								</div>
							</a>
						))}
					</div>
				</section>
			</div>
		)
	}

	<script>
		// Reading progress bar
		const bar = document.getElementById("readbar");
		if (bar) {
			const update = () => {
				const max =
					document.documentElement.scrollHeight - window.innerHeight;
				const p = max > 0 ? Math.min(100, (window.scrollY / max) * 100) : 0;
				(bar as HTMLElement).style.width = p + "%";
			};
			window.addEventListener("scroll", update, { passive: true });
			update();
		}
	</script>

	<script>
		// Build TOC and activate links on scroll
		function buildToc() {
			const prose = document.getElementById("article-prose");
			const toc = document.getElementById("toc-content");
			if (!prose || !toc) return;

			const headings = prose.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				const widget = toc.closest(".widget") as HTMLElement | null;
				if (widget) widget.style.display = "none";
				return;
			}

			headings.forEach((h, i) => {
				if (!h.id) h.id = `heading-${i}`;
				const a = document.createElement("a");
				a.href = `#${h.id}`;
				a.textContent = h.textContent;
				a.className =
					h.tagName === "H3" ? "toc-link toc-link--nested" : "toc-link";
				toc.appendChild(a);
			});

			const links = [...toc.querySelectorAll<HTMLAnchorElement>(".toc-link")];
			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							links.forEach((l) => l.classList.remove("active"));
							const link = links.find(
								(l) => l.getAttribute("href") === `#${e.target.id}`,
							);
							if (link) link.classList.add("active");
						}
					});
				},
				{ rootMargin: "-20% 0px -70% 0px" },
			);

			headings.forEach((h) => io.observe(h));
		}

		buildToc();
	</script>
</Base>

<style>
	/* ── Reading progress bar ── */
	.readbar {
		position: fixed;
		top: 0;
		left: 0;
		height: 4px;
		background: var(--color-accent);
		width: 0%;
		transition: width 0.08s linear;
		z-index: 200;
	}

	/* ── Layout shell ── */
	.post-wrap {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 var(--spacing-6);
	}

	/* ── Grid lines overlay ── */
	.grid-lines {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background-image: linear-gradient(
			to right,
			var(--color-border) 1px,
			transparent 1px
		);
		background-size: 25% 100%;
		opacity: 0.4;
	}

	/* ── POST HEADER ── */
	.post-head {
		position: relative;
		padding: 3.125rem 0 2.25rem;
	}

	.crumb {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
		display: inline-flex;
		align-items: center;
		gap: 0.5625rem;
		margin-bottom: 1.75rem;
	}

	.crumb a:hover {
		color: var(--color-text);
	}

	.crumb-arrow {
		color: var(--color-accent);
	}

	.metarow {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		margin-bottom: 1.125rem;
		flex-wrap: wrap;
	}

	.tag-pill {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.meta-mono {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-muted);
		letter-spacing: 0.02em;
	}

	.post-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(2.5rem, 7.4vw, 5.25rem);
		line-height: 0.92;
		letter-spacing: -0.038em;
		margin: 0;
		max-width: 14ch;
		text-wrap: balance;
	}

	.post-dek {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(1.25rem, 2.4vw, 1.6875rem);
		line-height: 1.32;
		letter-spacing: -0.015em;
		color: var(--color-text-secondary);
		max-width: 30ch;
		margin: 1.625rem 0 0;
	}

	/* Byline bar */
	.byline-bar {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		flex-wrap: wrap;
		margin-top: 2.125rem;
		padding: 1.125rem 0;
		border-top: 1.5px solid var(--color-text);
		border-bottom: 1.5px solid var(--color-text);
	}

	.byline-left {
		display: flex;
		align-items: center;
		gap: 0.875rem;
	}

	.byline-sq {
		width: 44px;
		height: 44px;
		flex-shrink: 0;
		border: 1.5px solid var(--color-text);
		background: var(--color-accent);
		color: var(--color-on-accent);
		font-family: var(--font-mono);
		font-weight: 600;
		font-size: 0.875rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.byline-sq-img {
		object-fit: cover;
		background: var(--color-surface);
	}

	.byline-name {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.9375rem;
	}

	.byline-sub {
		font-family: var(--font-mono);
		font-size: 0.71875rem;
		color: var(--color-muted);
		margin-top: 2px;
	}

	.byline-actions {
		margin-left: auto;
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.abtn {
		font-family: var(--font-mono);
		font-size: 0.78125rem;
		font-weight: 500;
		padding: 0.5625rem 0.875rem;
		border: 1.5px solid var(--color-text);
		background: transparent;
		color: var(--color-text);
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
		text-decoration: none;
		transition:
			transform 0.14s,
			box-shadow 0.14s;
	}

	.abtn:hover {
		transform: translate(-2px, -2px);
		box-shadow: 4px 4px 0 var(--color-accent);
		color: var(--color-text);
	}

	/* ── HERO IMAGE ── */
	.hero-fig {
		margin: 0 0 3.125rem;
	}

	.hero-img-wrap {
		width: 100%;
		aspect-ratio: 21 / 9;
		overflow: hidden;
		border: 1.5px solid var(--color-text);
		background: var(--color-surface);
	}

	.hero-img-wrap :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: grayscale(0.15) contrast(1.02);
	}

	.hero-cap {
		font-family: var(--font-mono);
		font-size: 0.71875rem;
		color: var(--color-muted);
		margin-top: 0.625rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.hero-dot {
		color: var(--color-accent);
	}

	/* ── TWO-COLUMN LAYOUT ── */
	.post-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 3.5rem;
		padding-bottom: 4rem;
		align-items: start;
	}

	/* ── PROSE ── */
	.prose {
		max-width: 660px;
		font-family: var(--font-serif);
		font-size: 1.21875rem;
		line-height: 1.68;
		color: var(--color-text-secondary);
	}

	.prose :global(p) {
		margin: 0 0 1.5625rem;
	}

	/* Drop-cap on first paragraph */
	.prose :global(> p:first-child::first-letter) {
		font-family: var(--font-display);
		font-weight: 800;
		float: left;
		font-size: 4.6em;
		line-height: 0.72;
		padding: 8px 14px 0 0;
		color: var(--color-accent);
	}

	/* Numbered h2 headings */
	.prose {
		counter-reset: section;
	}

	.prose :global(h2) {
		counter-increment: section;
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--color-text);
		font-size: clamp(1.625rem, 3.4vw, 2.25rem);
		letter-spacing: -0.026em;
		line-height: 1.04;
		margin: 3.5rem 0 1.25rem;
		display: flex;
		align-items: baseline;
		gap: 0.9375rem;
		scroll-margin-top: calc(var(--nav-height) + 1.5rem);
	}

	.prose :global(h2)::before {
		content: counter(section, decimal-leading-zero);
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-accent);
		flex-shrink: 0;
	}

	.prose :global(h3) {
		font-family: var(--font-display);
		font-weight: 600;
		color: var(--color-text);
		font-size: clamp(1.25rem, 2.4vw, 1.5rem);
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin: 2.5rem 0 0.75rem;
		scroll-margin-top: calc(var(--nav-height) + 1.5rem);
	}

	.prose :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.prose :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}

	.prose :global(a:hover) {
		text-decoration-thickness: 2px;
	}

	/* Pull-quote: full-width vermillion slab */
	.prose :global(blockquote) {
		position: relative;
		margin: 3.125rem 0;
		padding: 2.375rem 2.25rem;
		background: var(--color-accent);
		color: var(--color-on-accent);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(1.6875rem, 3.8vw, 2.5rem);
		letter-spacing: -0.026em;
		line-height: 1.12;
		font-style: normal;
		border: none;
		border-radius: 0;
	}

	.prose :global(blockquote)::before {
		content: "\201C";
		position: absolute;
		top: -6px;
		left: 20px;
		font-family: var(--font-display);
		font-size: 5.75rem;
		line-height: 1;
		opacity: 0.3;
		pointer-events: none;
	}

	.prose :global(blockquote p) {
		margin: 0;
		font-family: inherit;
		font-size: inherit;
		color: inherit;
		line-height: inherit;
	}

	.prose :global(blockquote cite) {
		display: block;
		margin-top: 1.125rem;
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 500;
		font-style: normal;
		opacity: 0.8;
		letter-spacing: 0.02em;
	}

	/* Code */
	.prose :global(pre) {
		margin: 2rem 0;
		padding: var(--spacing-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		line-height: 1.6;
	}

	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-surface);
		padding: 0.2em 0.4em;
		border-radius: var(--radius);
	}

	.prose :global(pre code) {
		background: none;
		padding: 0;
		font-size: inherit;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.5rem;
	}

	.prose :global(hr) {
		margin: 3rem 0;
		border: none;
		border-top: 1.5px solid var(--color-text);
	}

	.prose :global(img) {
		width: 100%;
		height: auto;
		border: 1.5px solid var(--color-border);
		display: block;
		margin: 2rem 0;
	}

	/* ── END MATTER ── */
	.endmatter {
		margin-top: 2.875rem;
		padding-top: 1.375rem;
		border-top: 1.5px solid var(--color-text);
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.875rem;
	}

	.endmatter-note {
		font-family: var(--font-mono);
		font-size: 0.78125rem;
